  create view "mobility"."gold"."fact_bike_demand__dbt_tmp"
    
    
  as (
    with base as (

    select
        trip_timestamp,
        trip_date,
        trip_hour,
        day_name,
        weather_code,
        season,
        cnt as bike_count,
        temperature_real_c,
        temperature_feels_like_c,
        humidity,
        wind_speed,
        is_holiday,
        is_weekend
    from "mobility"."silver"."stg_cycle_trips"

),

dim_date as (

    select * from "mobility"."gold"."dim_date"

),

dim_weather as (

    select * from "mobility"."gold"."dim_weather"

)

select
    md5(cast(base.trip_timestamp as varchar)) as demand_key,
    dim_date.date_key,
    dim_weather.weather_key,
    base.trip_timestamp,
    base.trip_hour,
    base.day_name,
    base.bike_count,
    
    case
        when base.bike_count < 100 then 'low'
        when base.bike_count between 100 and 500 then 'medium'
        else 'high'
    end
 as demand_level,
    base.is_holiday,
    base.is_weekend
from base
left join dim_date
    on base.trip_date = dim_date.date_day
left join dim_weather
    on md5(
        cast(base.weather_code as varchar) || '-' ||
        cast(base.season as varchar) || '-' ||
        cast(base.temperature_real_c as varchar) || '-' ||
        cast(base.temperature_feels_like_c as varchar) || '-' ||
        cast(base.humidity as varchar) || '-' ||
        cast(base.wind_speed as varchar)
    ) = dim_weather.weather_key
  );
