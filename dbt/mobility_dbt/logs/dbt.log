  create view "mobility"."gold"."dim_date__dbt_tmp"
    
    
  as (
    select distinct
    md5(cast(coalesce(cast(trip_date as TEXT), '_dbt_utils_surrogate_key_null_') as TEXT)) as date_key,
    trip_date as date_day,
    year,
    month,
    week_of_year,
    day_of_week,
    case
        when day_of_week = 0 then 'Sunday'
        when day_of_week = 1 then 'Monday'
        when day_of_week = 2 then 'Tuesday'
