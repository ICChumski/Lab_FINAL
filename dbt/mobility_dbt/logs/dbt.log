    md5(cast(coalesce(cast(trip_id as TEXT), '_dbt_utils_surrogate_key_null_') as TEXT)) as trip_key,
    md5(cast(coalesce(cast(start_station_id as TEXT), '_dbt_utils_surrogate_key_null_') || '-' || coalesce(cast(start_station_name as TEXT), '_dbt_utils_surrogate_key_null_') as TEXT)) as start_station_key,
    md5(cast(coalesce(cast(end_station_id as TEXT), '_dbt_utils_surrogate_key_null_') || '-' || coalesce(cast(end_station_name as TEXT), '_dbt_utils_surrogate_key_null_') as TEXT)) as end_station_key,
    md5(cast(coalesce(cast(trip_date as TEXT), '_dbt_utils_surrogate_key_null_') as TEXT)) as date_key,

    start_station_id,
    end_station_id,

    started_at,
    ended_at,

    trip_duration_minutes,
    trip_duration_seconds,
    
    case
        when trip_duration_minutes < 10 then 'short'
        when trip_duration_minutes < 30 then 'medium'
        else 'long'
    end
 as duration_bucket,

    trip_date,
    trip_hour,
    day_of_week,
    week_of_year,
    month,
    year,

    bike_id,
    bike_model,

    is_round_trip

from "mobility"."silver"."stg_cycle_trips"
  );
